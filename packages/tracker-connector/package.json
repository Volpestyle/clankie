{
  "name": "@clankie/tracker-connector",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:live": "CLANKIE_LINEAR_LIVE_SMOKE=1 CLANKIE_LINEAR_AGENT_LIVE_SMOKE=1 vitest run test/*-live.test.ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@clankie/protocol": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
