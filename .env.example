# Local control plane and runner
CLANKIE_CONTROL_PLANE_URL=http://127.0.0.1:4310
CLANKIE_RUNNER_URL=http://127.0.0.1:4311
CLANKIE_RELAY_URL=ws://127.0.0.1:4320
CLANKIE_RELAY_DEV_TOKEN=replace-with-at-least-16-random-characters
CLANKIE_DATA_DIR=.data
CLANKIE_LOG_LEVEL=debug
CLANKIE_DOCTRINE=doctrine/profiles/self-build-lab.yaml

# Eve captain
CAPTAIN_MODEL=anthropic/claude-sonnet-5
AI_GATEWAY_API_KEY=

# Worker providers. Keep provider-native credentials on the runner host.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CODEX_HOME=
CLAUDE_CONFIG_DIR=
CLANKIE_CODEX_ENABLED=false
CLANKIE_CODEX_EXECUTABLE=codex
CLANKIE_CODEX_MODEL=
CLANKIE_CLAUDE_ENABLED=false
CLANKIE_CLAUDE_EXECUTABLE=
CLANKIE_CLAUDE_MODEL=
CLANKIE_PI_ENABLED=false
CLANKIE_PI_MODEL=
CLANKIE_PI_OLLAMA_URL=http://127.0.0.1:11434
CLANKIE_NONINTERACTIVE_WAITING_USER=block

# Optional telemetry and crash reporting
OTEL_SERVICE_NAME=clankie-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
CLANKIE_ANALYTICS_ENABLED=false

# Official Discord bot credentials only. Never use a Discord user token.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
CLANKIE_API_URL=http://127.0.0.1:4310
