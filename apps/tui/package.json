{
  "name": "@clankie/tui",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "clankie": "./bin/clankie.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@clankie/api-client": "workspace:*",
    "@clankie/credential-broker": "workspace:*",
    "@clankie/model-provider": "workspace:*",
    "@clankie/model-registry": "workspace:*",
    "@clankie/observability": "workspace:*",
    "@clankie/protocol": "workspace:*",
    "@earendil-works/pi-tui": "0.80.6",
    "chalk": "5.6.2",
    "eve": "0.22.4"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
