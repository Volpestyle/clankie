{
  "name": "@clankie/linear-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@clankie/api-client": "workspace:*",
    "@clankie/observability": "workspace:*",
    "@clankie/protocol": "workspace:*",
    "@clankie/tracker-connector": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
